spring.application.name=ai-analysis-service
server.port=8083

# ===== Gemini API =====
# WICHTIG: Eigenen API-Key hier eintragen (https://aistudio.google.com/apikey)
gemini.api.key=AIzaSyAb_ijULdOm5kECH6fa3TVvgecZID0WqEk
gemini.model=gemini-2.5-flash-lite
gemini.timeout-seconds=600

# ===== Smart Sampling =====
# Maximale Stichproben-Zeilen pro Datei die an Gemini gesendet werden.
# Statistiken werden trotzdem ueber ALLE Zeilen berechnet.
prompt.default-sample-rows=50

# ===== Eureka =====
eureka.client.service-url.defaultZone=http://localhost:8761/eureka/
eureka.client.register-with-eureka=true
eureka.client.fetch-registry=true
eureka.instance.prefer-ip-address=true

# ===== Logging =====
logging.level.de.bht.app.aianalysis=DEBUG

